{
  "structured-text.serverPath": "${workspaceFolder}/../target/debug/st-cli",
  "editor.semanticHighlighting.enabled": true,
  "files.associations": {
    "*.st": "structured-text",
    "*.scl": "structured-text"
  },
  "[structured-text]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.autoClosingBrackets": "always",
    "editor.formatOnSave": false
  }
}
