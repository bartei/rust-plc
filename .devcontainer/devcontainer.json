{
  "name": "IEC 61131-3 ST Development",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer"
      ],
      "settings": {
        "structured-text.serverPath": "${workspaceFolder}/target/debug/st-cli",
        "editor.semanticHighlighting.enabled": true,
        "files.associations": {
          "*.st": "structured-text",
          "*.scl": "structured-text"
        },
        "[structured-text]": {
          "editor.tabSize": 4,
          "editor.insertSpaces": true,
          "editor.autoClosingBrackets": "always"
        }
      }
    }
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    }
  }
}
