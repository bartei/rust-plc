{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build st-cli",
      "type": "shell",
      "command": "cargo build -p st-cli",
      "problemMatcher": ["$rustc"],
      "group": "build"
    },
    {
      "label": "Build st-cli (release)",
      "type": "shell",
      "command": "cargo build -p st-cli --release",
      "problemMatcher": ["$rustc"],
      "group": "build"
    },
    {
      "label": "Test workspace",
      "type": "shell",
      "command": "cargo test --workspace",
      "problemMatcher": ["$rustc"],
      "group": "test"
    },
    {
      "label": "Compile VSCode extension",
      "type": "shell",
      "command": "cd editors/vscode && npm install && npm run compile",
      "problemMatcher": ["$tsc"],
      "group": "build"
    },
    {
      "label": "Build all (st-cli + extension)",
      "dependsOn": ["Build st-cli", "Compile VSCode extension"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build docs",
      "type": "shell",
      "command": "cd docs && mdbook build",
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Serve docs (live reload)",
      "type": "shell",
      "command": "cd docs && mdbook serve --open",
      "problemMatcher": [],
      "isBackground": true
    }
  ]
}